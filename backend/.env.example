DATABASE_URL=sqlite+aiosqlite:///./location_intel.db
CACHE_TTL_HOURS=24
CORS_ORIGINS=http://localhost:5173

# CPCB AQI — get a free key at https://data.gov.in/user/register
DATA_GOV_API_KEY=

# Google Maps Platform — Geocoding API, Places API (New), Routes API
GOOGLE_MAPS_API_KEY=
LOCATION_PROVIDER=hybrid
GOOGLE_PLACES_MAX_RESULTS_PER_TYPE=20
GOOGLE_PLACES_ENABLE_DETAILS=false

# Cache TTLs for Google responses (hours)
GOOGLE_GEOCODE_CACHE_TTL_HOURS=720
GOOGLE_PLACES_CACHE_TTL_HOURS=168
GOOGLE_ROUTES_CACHE_TTL_HOURS=24

# Google ADK / Gemini chatbot
GOOGLE_GENAI_API_KEY=
GOOGLE_ADK_MODEL=gemini-2.0-flash
ADK_ENABLE_CHAT=true
ADK_SESSION_BACKEND=sqlite
ADK_MAX_TOOL_CALLS=8
ADK_MAX_CONTEXT_REPORT_CHARS=30000

# Optional: Vertex AI instead of Gemini API
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=false
